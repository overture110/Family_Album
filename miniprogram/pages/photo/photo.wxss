/* 照片详情页样式 */
.container {
  padding: 20rpx;
}

.photo-view {
  width: 100%;
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.photo-image {
  max-width: 100%;
  max-height: 100%;
}

.photo-info {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  background: #8B7355;
  color: white;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
}

.action-btn:active {
  opacity: 0.8;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 200rpx;
  color: #999;
}
