/* 相册详情页样式 */
.container {
  padding: 20rpx;
}

.album-header {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.album-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.album-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #8B7355;
  margin-bottom: 12rpx;
}

.album-date {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.album-count {
  font-size: 24rpx;
  color: #999;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 12rpx;
}

.photo-grid .photo-item {
  width: calc(33.33% - 8rpx);
  aspect-ratio: 1;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.photo-grid .photo-item image {
  width: 100%;
  height: 100%;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 200rpx;
  color: #999;
}
